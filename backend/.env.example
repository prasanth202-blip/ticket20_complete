# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/ticketflow

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_key_minimum_32_chars
JWT_EXPIRE=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=noreply@ticketflow.com
FROM_NAME=TicketFlow

# Platform Admin (used by seed.js)
PLATFORM_EMAIL=admin@ticketflow.com
PLATFORM_PASSWORD=Admin@123

# Razorpay (get test keys from https://dashboard.razorpay.com/app/keys)
# Leave empty to run in DEMO mode (no real charges)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# File uploads
MAX_FILE_SIZE=10485760
